# compass-mcp — env example
# Core scoring needs no secrets.
#
# Optional (stdio / local):
# COMPASS_MCP_HOST=cursor   # cursor | claude | openai | generic (forge/openclaw→generic)
# COMPASS_MCP_DATA_DIR=~/.cursor/compass-mcp
# COMPASS_MCP_USAGE_PATH=/custom/path/usage.jsonl
# Legacy aliases still work: MODEL_ROUTER_HOST, MODEL_ROUTER_USAGE_PATH
#
# --- Remote HTTP MCP (Claude.ai / ChatGPT / Cursor URL) ---
# Start: npm run start:http  →  http://127.0.0.1:3920/mcp
#
# COMPASS_MCP_API_KEY=your-long-random-secret   # Bearer token (required for tunnel/production)
# COMPASS_MCP_HOST=127.0.0.1                    # bind address (0.0.0.0 for VPS; key required)
# COMPASS_MCP_PORT=3920
# COMPASS_MCP_PATH=/mcp
# COMPASS_MCP_CORS=https://claude.ai,https://chatgpt.com   # or * for dev only
# COMPASS_MCP_ALLOW_REMOTE_NO_KEY=true          # dev only — skip key for non-local (never in prod)
